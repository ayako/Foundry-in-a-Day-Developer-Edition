# Foundry Project Endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT="https://<YOUR-RESOURCE-NAME>.services.ai.azure.com/api/projects/<YOUR-PROJECT-NAME>"

# Model Deployment Name (Foundry でデプロイ済みのモデル名)
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-4.1-mini"

# Agent Name (Foundry に登録するエージェント名)
MICROSOFT_FOUNDRY_AGENT_NAME="zava-support-agent-x"

# Azure Tenant ID (マルチテナント環境の場合に指定)
AZURE_TENANT_ID="<YOUR-TENANT-ID>"
